{
  "manifest_version": 3,
  "name": "Auto Hitter",
  "version": "1.0.1",
  "description": "The next generation of automation",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "downloads",
    "clipboardWrite",
    "tabs",
    "webNavigation",
    "alarms",
    "proxy",
    "webRequest",
    "webRequestAuthProvider",
    "browsingData"
  ],
  "host_permissions": [ "https://autohittertesetmode.onrender.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "script/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*c/pay/cs_live_*",
        "*://*/*pay/cs_live_*",
        "*://*/*/checkout/*/cs_live_*",
        "*://buy.stripe.com/*",
        "*://invoice.stripe.com/*",
        "*://donate.stripe.com/*",
        "*://checkout.stripe.com/*"
      ],
      "js": ["script/content.js", "script/bypass_checkout.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.hcaptcha.com/*",
        "*://hcaptcha.com/*",
        "*://newassets.hcaptcha.com/*"
      ],
      "js": ["script/hcaptcha.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "script/inject.js",
        "script/storage.js",
        "script/autofill.js",
        "script/proxyhandler.js",
        "script/binlibrary.js",
        "script/countrylist.json",
        "script/countrylist.js",
        "script/miniapp.js", "miniapp.html", "styles.css",
        "sounds/hit.wav",
        "sounds/music.mp3",
        "icons/icon128.png",
        "fonts/SpaceGrotesk-Light.woff2",
        "fonts/SpaceGrotesk-Regular.woff2",
        "fonts/SpaceGrotesk-Medium.woff2",
        "fonts/SpaceGrotesk-SemiBold.woff2",
        "fonts/SpaceGrotesk-Bold.woff2"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Auto Hitter Dashboard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
